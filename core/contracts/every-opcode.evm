/////////////////////////////////////////////////////////////////////////////
// Section 10: Deploy helper contract + CALL, CALLCODE, DELEGATECALL, STATICCALL
// Helper: a contract that just STOPs (1 byte runtime)
// Init code (12 bytes): PUSH1 1 PUSH1 0x0b PUSH1 0 CODECOPY PUSH1 1 PUSH1 0 RETURN 00
// = 6001 600b 6000 39 6001 6000 f3 00
// Stack before: [acc]
// Stack after CREATE: [helper_addr, acc]
/////////////////////////////////////////////////////////////////////////////
// Init code (12 bytes) + runtime (1 byte STOP)
// PUSH1 1 PUSH1 0x0c PUSH1 0 CODECOPY PUSH1 1 PUSH1 0 RETURN | 00
MSTORE(0x100, 0x6001600c60003960016000f30000000000000000000000000000000000000000)
CREATE(0, 0x100, 13)

// CALL(gas=0x1000, addr=helper, value=0, argsOff=0, argsSize=0, retOff=0, retSize=0)
// Stack: [helper_addr, acc]
0
0
0
0
0
DUP6
0x1000
CALL
// Stack: [result(1), helper_addr, acc]
SWAP2
ADD
SWAP1
// Stack: [helper_addr, acc']

// CALLCODE(gas=0x1000, addr=helper, value=0, argsOff=0, argsSize=0, retOff=0, retSize=0)
0
0
0
0
0
DUP6
0x1000
CALLCODE
// Stack: [result(1), helper_addr, acc]
SWAP2
ADD
SWAP1
// Stack: [helper_addr, acc']

// DELEGATECALL(gas=0x1000, addr=helper, argsOff=0, argsSize=0, retOff=0, retSize=0)
0
0
0
0
DUP5
0x1000
DELEGATECALL
// Stack: [result(1), helper_addr, acc]
SWAP2
ADD
SWAP1
// Stack: [helper_addr, acc']

// STATICCALL(gas=0x1000, addr=helper, argsOff=0, argsSize=0, retOff=0, retSize=0)
0
0
0
0
DUP5
0x1000
STATICCALL
// Stack: [result(1), helper_addr, acc]
SWAP2
ADD
SWAP1
// Stack: [helper_addr, acc']

/////////////////////////////////////////////////////////////////////////////
// Section 11: EXTCODESIZE, EXTCODECOPY, EXTCODEHASH
// Stack: [helper_addr, acc]
/////////////////////////////////////////////////////////////////////////////

// EXTCODESIZE + accumulate
DUP1
EXTCODESIZE
DUP3
ADD
SWAP2
POP
// Stack: [helper_addr, acc']

// EXTCODEHASH + accumulate
DUP1
EXTCODEHASH
DUP3
XOR
SWAP2
POP
// Stack: [helper_addr, acc'']

// EXTCODECOPY: copy helper code to memory 0x100
// EVM pops: addr(TOS), destOffset, offset, size
// So push in order: size(first/deepest), offset, destOffset, addr(last/top)
DUP1          // [helper_addr, helper_addr, acc]
EXTCODESIZE   // [size, helper_addr, acc]
0             // [0, size, helper_addr, acc]
0x100         // [0x100, 0, size, helper_addr, acc]
DUP4          // [helper_addr, 0x100, 0, size, helper_addr, acc]
EXTCODECOPY   // pops addr=helper_addr, dest=0x100, offset=0, size
// Stack: [helper_addr, acc'']

POP
// Stack: [acc]

/////////////////////////////////////////////////////////////////////////////
// Section 12: CALLDATACOPY, SHA3, MLOAD, MCOPY
/////////////////////////////////////////////////////////////////////////////

// CALLDATACOPY
CALLDATACOPY(0x200, 0, CALLDATASIZE)

// SHA3: hash 32 bytes at 0x200, fold into acc
32
0x200
SHA3
XOR

// MLOAD
MLOAD(0x100)
ADD

// MSIZE
MSIZE
ADD

// PC
PC
ADD

// MCOPY: copy 32 bytes from 0 to 0x300
MCOPY(0x300, 0, 32)

/////////////////////////////////////////////////////////////////////////////
// Section 13: RETURNDATASIZE, RETURNDATACOPY
/////////////////////////////////////////////////////////////////////////////

// RETURNDATASIZE (should be 0 after CREATE, but exercises opcode)
RETURNDATASIZE
ADD

// RETURNDATACOPY: copy 0 bytes (safe regardless of RETURNDATASIZE)
RETURNDATACOPY(0x300, 0, 0)

/////////////////////////////////////////////////////////////////////////////
// Section 14: Precompile calls
// Each precompile: set up input in memory, CALL with 100000 gas, read output, XOR into acc
// Stack: [acc]
/////////////////////////////////////////////////////////////////////////////

// --- ECRECOVER (0x1) ---
MSTORE(0x200, 0x456e9aea5e197a1f1af7a3e85a3212fa4049a3ba34c2289b4c860fc0b0c64ef3)
MSTORE(0x220, 28)
MSTORE(0x240, 0x9242685bf161793cc25603c231bc2f568eb630ea16aa137d2664ac8038825608)
MSTORE(0x260, 0x4f8ae3bd7535248d0bd448298cc2e2071e56992d0774dc340c368ae950852ada)
CALL(100000, ECRECOVER, 0, 0x200, 128, 0x200, 32)
ADD
MLOAD(0x200)
XOR

// --- SHA2_256 (0x2) ---
CALL(100000, SHA2_256, 0, 0x200, 32, 0x200, 32)
ADD
MLOAD(0x200)
XOR

// --- RIPEMD160 (0x3) ---
CALL(100000, RIPEMD160, 0, 0x200, 32, 0x200, 32)
ADD
MLOAD(0x200)
XOR

// --- IDENTITY (0x4) ---
CALL(100000, IDENTITY, 0, 0x200, 32, 0x280, 32)
ADD
MLOAD(0x280)
XOR

// --- MODEXP (0x5) ---
// baseLen=32, expLen=32, modLen=32, base=2, exp=10, mod=1000
MSTORE(0x400, 32)
MSTORE(0x420, 32)
MSTORE(0x440, 32)
MSTORE(0x460, 2)
MSTORE(0x480, 10)
MSTORE(0x4A0, 1000)
CALL(100000, MODEXP, 0, 0x400, 192, 0x400, 32)
ADD
MLOAD(0x400)
XOR

// --- EC_ADD (0x6) ---
// P1 = generator (1, 2), P2 = known point
MSTORE(0x600, 1)
MSTORE(0x620, 2)
MSTORE(0x640, 0x1c76476f4def4bb94541d57ebba1193381ffa7aa76ada664dd31c16024c43f59)
MSTORE(0x660, 0x3034dd2920f673e204fee2811c678745fc819b55d3e9d294e45c9b03a76aef41)
CALL(100000, EC_ADD, 0, 0x600, 128, 0x600, 64)
ADD
MLOAD(0x600)
XOR
MLOAD(0x620)
XOR

// --- EC_MUL (0x7) ---
// G = (1, 2), scalar = 2
MSTORE(0x600, 1)
MSTORE(0x620, 2)
MSTORE(0x640, 2)
CALL(100000, EC_MUL, 0, 0x600, 96, 0x600, 64)
ADD
MLOAD(0x600)
XOR
MLOAD(0x620)
XOR

// --- EC_PAIRING (0x8) ---
// One pairing pair (192 bytes)
MSTORE(0x700, 0x1c76476f4def4bb94541d57ebba1193381ffa7aa76ada664dd31c16024c43f59)
MSTORE(0x720, 0x3034dd2920f673e204fee2811c678745fc819b55d3e9d294e45c9b03a76aef41)
MSTORE(0x740, 0x209dd15ebff5d46c4bd888e51a93cf99a7329636c63514396b4a452003a35bf7)
MSTORE(0x760, 0x04bf11ca01483bfa8b34b43561848d28905960114c8ac04049af4b6315a41678)
MSTORE(0x780, 0x2bb8324af6cfc93537a2ad1a445cfd0ca2a71acd7ac41fadbf933c2a51be344d)
MSTORE(0x7A0, 0x120a2a4cf30c1bf9845f20c6fe39e07ea2cce61f0c9bb048165fe5e4de877550)
CALL(100000, EC_PAIRING, 0, 0x700, 192, 0x700, 32)
ADD
MLOAD(0x700)
XOR

// --- BLAKE2F (0x9) ---
// 213 bytes: rounds(4) + h(64) + m(128) + t(16) + f(1)
MSTORE(0x800, 0x0000000148c9bdf267e6096a3ba7ca8485ae67bb2bf894fe72f36e3cf1361d5f)
MSTORE(0x820, 0x3af54fa5d182e6ad7f520e511f6c3e2b8c68059b6bbd41fbabd9831f79217e13)
MSTORE(0x840, 0x19cde05b61626300000000000000000000000000000000000000000000000000)
MSTORE(0x860, 0)
MSTORE(0x880, 0)
MSTORE(0x8A0, 0)
MSTORE(0x8C0, 0x0000000003000000000000000000000000000000010000000000000000000000)
CALL(100000, BLACK2F, 0, 0x800, 213, 0x800, 64)
ADD
MLOAD(0x800)
XOR
MLOAD(0x820)
XOR

// --- ZKG_POINT / POINT_EVAL (0xa) ---
MSTORE(0x900, 0x01e798154708fe7789429634053cbf9f99b619f9f084048927333fce637f549b)
MSTORE(0x920, 0x564c0a11a0f704f4fc3e8acfe0f8245f0ad1347b378fbf96e206da11a5d36306)
MSTORE(0x940, 0x24d25032e67a7e6a4910df5834b8fe70e6bcfeeac0352434196bdf4b2485d5a1)
MSTORE(0x960, 0x8f59a8d2a1a625a17f3fea0fe5eb8c896db3764f3185481bc22f91b4aaffcca2)
MSTORE(0x980, 0x5f26936857bc3a7c2539ea8ec3a952b7873033e038326e87ed3e1276fd140253)
MSTORE(0x9A0, 0xfa08e9fc25fb2d9a98527fc22a2c9612fbeafdad446cbc7bcdbdcd780af2c16a)
CALL(100000, ZKG_POINT, 0, 0x900, 192, 0x900, 64)
ADD
MLOAD(0x900)
XOR
MLOAD(0x920)
XOR

// --- bls12381G1Add (0x0b) ---
// Input: 2 x G1 point (each 128 bytes) = 256 bytes
// Using G1 generator for both points (computes G+G = 2G)
// P1.x (64 bytes padded)
MSTORE(0xC00, 0x0000000000000000000000000000000017f1d3a73197d7942695638c4fa9ac0f)
MSTORE(0xC20, 0xc3688c4f9774b905a14e3a3f171bac586c55e83ff97a1aeffb3af00adb22c6bb)
// P1.y (64 bytes padded)
MSTORE(0xC40, 0x0000000000000000000000000000000008b3f481e3aaa0f1a09e30ed741d8ae4)
MSTORE(0xC60, 0xfcf5e095d5d00af600db18cb2c04b3edd03cc744a2888ae40caa232946c5e7e1)
// P2 = same as P1
MSTORE(0xC80, 0x0000000000000000000000000000000017f1d3a73197d7942695638c4fa9ac0f)
MSTORE(0xCA0, 0xc3688c4f9774b905a14e3a3f171bac586c55e83ff97a1aeffb3af00adb22c6bb)
MSTORE(0xCC0, 0x0000000000000000000000000000000008b3f481e3aaa0f1a09e30ed741d8ae4)
MSTORE(0xCE0, 0xfcf5e095d5d00af600db18cb2c04b3edd03cc744a2888ae40caa232946c5e7e1)
CALL(100000, 0x0b, 0, 0xC00, 256, 0xC00, 128)
ADD
MLOAD(0xC00)
XOR
MLOAD(0xC20)
XOR
MLOAD(0xC40)
XOR
MLOAD(0xC60)
XOR

// --- bls12381G1MultiExp (0x0c) ---
// Input: G1 point (128 bytes) + scalar (32 bytes) = 160 bytes
// G1 generator * 2
MSTORE(0xD00, 0x0000000000000000000000000000000017f1d3a73197d7942695638c4fa9ac0f)
MSTORE(0xD20, 0xc3688c4f9774b905a14e3a3f171bac586c55e83ff97a1aeffb3af00adb22c6bb)
MSTORE(0xD40, 0x0000000000000000000000000000000008b3f481e3aaa0f1a09e30ed741d8ae4)
MSTORE(0xD60, 0xfcf5e095d5d00af600db18cb2c04b3edd03cc744a2888ae40caa232946c5e7e1)
// scalar = 2
MSTORE(0xD80, 2)
CALL(100000, 0x0c, 0, 0xD00, 160, 0xD00, 128)
ADD
MLOAD(0xD00)
XOR
MLOAD(0xD20)
XOR
MLOAD(0xD40)
XOR
MLOAD(0xD60)
XOR

