MSTORE(0x12E0, 0xc6e47ad4fa403b02b4510b647ae3d1770bac0326a805bbefd48056c8c121bdb8)
MSTORE(0x1300, 0x000000000000000000000000000000000606c4a02ea734cc32acd2b02bc28b99)
MSTORE(0x1320, 0xcb3e287e85a763af267492ab572e99ab3f370d275cec1da1aaa9075ff05f79be)
MSTORE(0x1340, 0x000000000000000000000000000000000ce5d527727d6e118cc9cdc6da2e351a)
MSTORE(0x1360, 0xadfd9baa8cbdd3a76d429a695160d12c923ac9cc3baca289e193548608b82801)
CALL(100000, 0x0f, 0, 0x1200, 384, 0x1200, 32)
ADD
MLOAD(0x1200)
XOR

// --- bls12381MapG1 (0x10) ---
// Input: 64-byte field element (padded), Output: 128-byte G1 point
MSTORE(0x1400, 0)
MSTORE(0x1420, 1)
CALL(100000, 0x10, 0, 0x1400, 64, 0x1400, 128)
ADD
MLOAD(0x1400)
XOR
MLOAD(0x1420)
XOR
MLOAD(0x1440)
XOR
MLOAD(0x1460)
XOR

// --- bls12381MapG2 (0x11) ---
// Input: 128-byte field element pair, Output: 256-byte G2 point
MSTORE(0x1500, 0)
MSTORE(0x1520, 1)
MSTORE(0x1540, 0)
MSTORE(0x1560, 1)
CALL(100000, 0x11, 0, 0x1500, 128, 0x1500, 256)
ADD
MLOAD(0x1500)
XOR
MLOAD(0x1520)
XOR
MLOAD(0x1540)
XOR
MLOAD(0x1560)
XOR
MLOAD(0x1580)
XOR
MLOAD(0x15A0)
XOR
MLOAD(0x15C0)
XOR
MLOAD(0x15E0)
XOR

// --- p256Verify (0x0100) ---
// Input: hash(32) + r(32) + s(32) + x(32) + y(32) = 160 bytes
MSTORE(0x1600, 0xbb5a52f42f9c9261ed4361f59422a1e30036e7c32b270c8807a419feca605023)
MSTORE(0x1620, 0x14b1e77b3e5c973fba2e72e147bf6fb3b8af857c36096cec46c9e34b4a098e05)
MSTORE(0x1640, 0x27fdc3fb14b2b221f2c9028c50d391b559b30c0f14eadb27ffb29b74f18cc70f)
MSTORE(0x1660, 0x69b7667056e1e11d6caf6e45643f8b21e7a4bebda463c7fdac0c052096de3efb)
MSTORE(0x1680, 0xfc1bf79c77e01da5e83ad16183c26c7b4afc2bbcac91b7587e524de0a4abb8c8)
CALL(100000, 0x0100, 0, 0x1600, 160, 0x1600, 32)
ADD
MLOAD(0x1600)
XOR

/////////////////////////////////////////////////////////////////////////////
// Section 15: TSTORE, TLOAD
/////////////////////////////////////////////////////////////////////////////
TSTORE(1, 0xCAFEBABE)
TLOAD(1)
ADD

/////////////////////////////////////////////////////////////////////////////
// Section 16: JUMP, JUMPI (using labels in main contract)
/////////////////////////////////////////////////////////////////////////////
JUMPI(skipjumpi, 1)
INVALID
skipjumpi:

JUMP(skipjump)
INVALID
skipjump:

/////////////////////////////////////////////////////////////////////////////
// Section 17: LOG0-LOG4
// Stack: [acc]
/////////////////////////////////////////////////////////////////////////////

// Store log data "John was here\n"
MSTORE(0xA00, 0x4a6f686e2077617320686572650a000000000000000000000000000000000000)

// LOG0(offset, size)
LOG0(0xA00, 14)

// LOG1(offset, size, topic1=acc)
DUP1
14
0xA00
LOG1

// LOG2(offset, size, topic1, topic2)
DUP1
DUP1
14
0xA00
LOG2

// LOG3(offset, size, topic1, topic2, topic3)
DUP1
DUP1
DUP1
14
0xA00
LOG3

// LOG4(offset, size, topic1, topic2, topic3, topic4)
DUP1
DUP1
DUP1
DUP1
14
0xA00
LOG4

/////////////////////////////////////////////////////////////////////////////
// Section 18: SSTORE, SLOAD
/////////////////////////////////////////////////////////////////////////////

// Store acc in slot 0x11235813
DUP1
0x11235813
SSTORE

// Load it back and AND (acc AND acc = acc)
0x11235813
SLOAD
AND

/////////////////////////////////////////////////////////////////////////////
// Section 19: Sub-contract deployments
// These exercise: CREATE, CREATE2, STOP, REVERT, INVALID, SELFDESTRUCT,
//                 JUMP+JUMPDEST (in sub-context), CLZ, BLOBHASH, BLOBBASEFEE
// Each sub-contract is deployed with a constructor that returns runtime code,
// then CALLed with 100000 gas so failures don't burn all remaining gas.
// CALL results (1=success, 0=failure) are ADDed into accumulator.
// Stack: [acc]
/////////////////////////////////////////////////////////////////////////////

// Test STOP: runtime = 00 (STOP)
// Constructor (12 bytes) + runtime (1 byte) = 13 bytes
MSTORE(0x100, 0x6001600c60003960016000f30000000000000000000000000000000000000000)
CALL(100000, CREATE(0, 0x100, 13), 0, 0, 0, 0, 0)
ADD

// Test JUMP + JUMPDEST: runtime = PUSH1 3 JUMP JUMPDEST STOP (60 03 56 5B 00)
// Constructor (12 bytes) + runtime (5 bytes) = 17 bytes
MSTORE(0x100, 0x6005600c60003960056000f36003565B00000000000000000000000000000000)
CALL(100000, CREATE(0, 0x100, 17), 0, 0, 0, 0, 0)
ADD

// CREATE2 with salt (reuse last deployed bytecode)
CALL(100000, CREATE2(0, 0x100, 17, 0xDEAD), 0, 0, 0, 0, 0)
ADD

// Test CLZ (opcode 0x1e, non-standard): runtime = PUSH1 1 CLZ POP STOP (6001 1e 50 00)
// Constructor (12 bytes) + runtime (5 bytes) = 17 bytes
MSTORE(0x100, 0x6005600c60003960056000f360011e5000000000000000000000000000000000)
CALL(100000, CREATE(0, 0x100, 17), 0, 0, 0, 0, 0)
ADD

// Test BLOBHASH: runtime = PUSH1 0 BLOBHASH POP STOP (60 00 49 50 00)
// Constructor (12 bytes) + runtime (5 bytes) = 17 bytes
MSTORE(0x100, 0x6005600c60003960056000f36000495000000000000000000000000000000000)
CALL(100000, CREATE(0, 0x100, 17), 0, 0, 0, 0, 0)
ADD

// Test BLOBBASEFEE: runtime = BLOBBASEFEE POP STOP (4A 50 00)
// Constructor (12 bytes) + runtime (3 bytes) = 15 bytes
MSTORE(0x100, 0x6003600c60003960036000f34A50000000000000000000000000000000000000)
CALL(100000, CREATE(0, 0x100, 15), 0, 0, 0, 0, 0)
ADD

// Test REVERT: runtime = PUSH1 0 DUP1 REVERT (60 00 80 FD)
// Constructor (12 bytes) + runtime (4 bytes) = 16 bytes
MSTORE(0x100, 0x6004600c60003960046000f3600080FD00000000000000000000000000000000)
CALL(100000, CREATE(0, 0x100, 16), 0, 0, 0, 0, 0)
ADD

// Test SELFDESTRUCT: runtime = PUSH1 0 SELFDESTRUCT (60 00 FF)
// Constructor (12 bytes) + runtime (3 bytes) = 15 bytes
MSTORE(0x100, 0x6003600c60003960036000f36000FF0000000000000000000000000000000000)
CALL(100000, CREATE(0, 0x100, 15), 0, 0, 0, 0, 0)
ADD

// Test INVALID: runtime = INVALID (FE) -- burns all gas given to CALL, limited to 100000
// Constructor (12 bytes) + runtime (1 byte) = 13 bytes
MSTORE(0x100, 0x6001600c60003960016000f3FE00000000000000000000000000000000000000)
CALL(100000, CREATE(0, 0x100, 13), 0, 0, 0, 0, 0)
ADD

/////////////////////////////////////////////////////////////////////////////
// Section 20: System contract calls (Bor + EIP system contracts)
// These may not exist on all networks; CALL result (1/0) is accumulated.
// Stack: [acc]
/////////////////////////////////////////////////////////////////////////////

// ValidatorContract (0x1000)
CALL(50000, 0x0000000000000000000000000000000000001000, 0, 0, 0, 0, 0)
ADD

// StateReceiverContract (0x1001)
CALL(50000, 0x0000000000000000000000000000000000001001, 0, 0, 0, 0, 0)
ADD

// BeaconRootsAddress (EIP-4788)
CALL(50000, 0x000F3df6D732807Ef1319fB7B8bB8522d0Beac02, 0, 0, 0, 0, 0)
ADD

// HistoryStorageAddress (EIP-2935)
CALL(50000, 0x0000F90827F1C53a10cb7A02335B175320002935, 0, 0, 0, 0, 0)
ADD

// WithdrawalQueueAddress (EIP-7002)
CALL(50000, 0x00000961Ef480Eb55e80D19ad83579A64c007002, 0, 0, 0, 0, 0)
ADD

// ConsolidationQueueAddress (EIP-7251)
CALL(50000, 0x0000BBdDc7CE488642fb579F8B00f3a590007251, 0, 0, 0, 0, 0)
ADD

// SystemAddress (system transaction sender)
CALL(50000, 0xffffFFFfFFffffffffffffffFfFFFfffFFFfFFfE, 0, 0, 0, 0, 0)
ADD

/////////////////////////////////////////////////////////////////////////////
// Section 21: Final SSTORE + RETURN
// Stack: [acc]
/////////////////////////////////////////////////////////////////////////////

// Store final accumulator in slot 0
DUP1
0
SSTORE

// Write acc to memory for RETURN
0xB00
MSTORE

// Return 32 bytes
RETURN(0xB00, 32)