# Environment for the upgrade-agglayer-060 scenario. Copy to .env and edit, or override inline.

# Kurtosis enclave name for this scenario's devnet.
ENCLAVE_NAME=agglayer-upgrade-060

# Kurtosis-CDK package to launch. Defaults to the local checkout so the network matches the
# args conventions of the repo you are working on. Alternatively pin the CI-validated ref:
#   KURTOSIS_CDK=github.com/0xPolygon/kurtosis-cdk@6f5c0f0cd2cce5cf11a025aade73b13664df8007
# (if you pin that ref, you may need to add `deploy_optimism_rollup: true` to chain.yml).
KURTOSIS_CDK=${HOME}/kurtosis-cdk

# Upgrade path: start on the current latest stable, upgrade to the release candidate.
AGGLAYER_IMAGE_STABLE=ghcr.io/agglayer/agglayer:0.5.1
AGGLAYER_IMAGE_RC=ghcr.io/agglayer/agglayer:0.6.0-rc.2

# Host port to publish the relaunched agglayer read-RPC on (once the node leaves Kurtosis's
# control, `kurtosis port print` can no longer reach it, so we expose it directly).
AGGLAYER_READRPC_HOST_PORT=14444

# Settlement wait tuning (seconds).
SETTLE_TIMEOUT=1200
SETTLE_RETRY_INTERVAL=20
# Max time to drain in-flight settlement before the upgrade (the quiesce gate).
QUIESCE_TIMEOUT=1200

# Set to "true" to keep the enclave + relaunched container after the run (for debugging).
KEEP_ENCLAVE=false

# polycli must match CI (see README). It lives at ~/go/bin and is added to PATH by run.sh.
POLYCLI_VERSION=v0.1.90
