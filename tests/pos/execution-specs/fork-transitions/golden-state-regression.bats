# bats test_tags=golden-state,regression,fork-transition
@test "golden-state: all fork entries in the golden file pass hash comparison" {
    # Sweep test — catches any fork added to the golden file that doesn't have
    # its own per-fork test above. Also surfaces partial failures across all forks.
    local total_forks passed_forks failed_forks
    total_forks=$(jq '.blocks | length' "${GOLDEN_FILE}")
    passed_forks=0
    failed_forks=0

    while IFS= read -r entry; do
        local fork_name fork_block
        fork_name=$(echo "$entry" | jq -r '.fork')
        fork_block=$(echo "$entry" | jq -r '.fork_block')

        [[ "$fork_block" -le 0 ]] && continue

        if _assert_fork_entry_matches "$entry"; then
            (( passed_forks++ )) || true
        else
            (( failed_forks++ )) || true
        fi
    done < <(jq -c '.blocks[]' "${GOLDEN_FILE}")

    echo "  Golden state check: ${passed_forks}/${total_forks} fork entries matched, ${failed_forks} failed" >&3

    [[ "$failed_forks" -eq 0 ]] || {
        echo "" >&2
        echo "SUMMARY: ${failed_forks} fork(s) failed the golden state check." >&2
        echo "To regenerate the golden file for an intentional state change:" >&2
        echo "  ./scripts/compute-golden-state.sh --bor-version ${GOLDEN_BOR_VERSION}" >&2
        return 1
    }
}
